# PenPlotter271 gateway configuration.
#
# This is a dpkg conffile: your edits survive package upgrades. After changing,
# restart the service:  sudo systemctl restart plotter-gateway
#
# Bind address. Ships as 0.0.0.0 so the app is reachable on the LAN with no SSH
# tunnel — but the daemon has NO built-in auth, so this exposes unauthenticated
# control of the machine to everyone on the network. Use it ONLY on a fully
# trusted LAN. If the network has untrusted devices, set this back to 127.0.0.1
# (loopback) and reach the app via an SSH tunnel, a VPN (e.g. Tailscale), or an
# authenticating reverse proxy.
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8717

# Serial device. Leave commented to auto-detect; or pin the stable udev symlink:
#PLOTTER_PATH=/dev/plotter

# Where the package serves the built GUI from, and where writable runtime state
# (remembered position + editable session) lives. Defaults match the package
# layout — normally no need to change these.
GATEWAY_DIST=/opt/penplotter271/dist
PLOTTER_STATE=/var/lib/penplotter271/.plotter-state.json
PLOTTER_SESSION=/var/lib/penplotter271/.session.json

# In-app updater: GitHub repo (owner/name) whose latest Release supplies the
# update .deb, and where the update oneshot records its progress.
GITHUB_REPO=LAB271/PenPlotter
UPDATE_STATUS=/var/lib/penplotter271/.update-status.json
